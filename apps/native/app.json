{
  "expo": {
    "name": "native",
    "slug": "native",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "native",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/NanumSquareR.ttf",
            "./assets/fonts/NanumSquareL.ttf",
            "./assets/fonts/NanumSquareB.ttf",
            "./assets/fonts/NanumSquareEB.ttf",
            "./assets/fonts/NanumSquare_acR.ttf",
            "./assets/fonts/NanumSquare_acL.ttf",
            "./assets/fonts/NanumSquare_acB.ttf",
            "./assets/fonts/NanumSquare_acEB.ttf"
          ],
          "android": {
            "fonts": [
              {
                "fontFamily": "NanumSquare",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/NanumSquareR.ttf",
                    "weight": 400
                  }
                ]
              }
            ]
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
